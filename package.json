{
  "name": "king-within",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/gen-version.mjs && next build",
    "start": "next start",
    "lint": "eslint",
    "build:cap": "node scripts/gen-version.mjs && cross-env BUILD_TARGET=capacitor next build",
